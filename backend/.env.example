# Copy this file to ".env" and fill in your real keys.
# The .env file is gitignored so your secrets stay private.

# OpenAI API key  ->  https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Tavily web search key  ->  https://app.tavily.com
TAVILY_API_KEY=tvly-your-tavily-key-here

# Model + app settings (sensible defaults; change if you like)
OPENAI_MODEL=gpt-4o-mini
DATABASE_URL=sqlite:///./project01.db
LOG_LEVEL=INFO
